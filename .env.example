# 复制本文件为 .env 并填入真实凭据
# .env 已在 .gitignore 排除，不会被 commit

# MyJob HTTPS（留空时自动生成 .boss_profile/tls/ 下的本地自签名证书）
MYJOB_TLS_CERT=
MYJOB_TLS_KEY=
# CLI 访问正式受信任证书时设为 true；本机 127.0.0.1 默认允许自签名证书
MYJOB_TLS_VERIFY=true

# MyJob Web 与管理员认证
MYJOB_SECURE_COOKIE=true
MYJOB_CORS_ORIGINS=https://127.0.0.1:5173,https://localhost:5173
MYJOB_SESSION_HOURS=12
# 可选：仅首次初始化时覆盖默认超级管理员 Admin / 123456*
MYJOB_SUPERADMIN_USERNAME=
MYJOB_SUPERADMIN_PASSWORD=

# 面试问答 Agent (interview/) MySQL 配置
INTERVIEW_DB_HOST=127.0.0.1
INTERVIEW_DB_PORT=3306
INTERVIEW_DB_USER=root
INTERVIEW_DB_PASSWORD=
INTERVIEW_DB_NAME=ai_jobs_db
