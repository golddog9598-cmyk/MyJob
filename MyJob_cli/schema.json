{
  "name": "MyJob CLI",
  "version": "0.0.9",
  "data_boundary": {
    "backend": ["MyJob account", "administrator analytics", "main resume", "static Vue files"],
    "client_only": ["platform login", "job search", "applications", "conversations", "campaigns", "platform statistics"],
    "client_storage": "IndexedDB"
  },
  "commands": [
    {
      "name": "status",
      "cli": "myjob status",
      "endpoint": "GET /api/health"
    },
    {
      "name": "open",
      "cli": "myjob open",
      "description": "Open the Vue workspace where all recruitment-platform operations run"
    },
    {
      "name": "resume",
      "cli": "myjob resume show|templates|upload|template|export",
      "endpoints": [
        "GET /api/resumes/master",
        "GET /api/resume-templates",
        "POST /api/resumes/upload",
        "PUT /api/resumes/master/template",
        "GET /api/resumes/master/export"
      ]
    },
    {
      "name": "architecture",
      "cli": "myjob architecture",
      "description": "Show the enforced browser-side platform data boundary"
    }
  ]
}
